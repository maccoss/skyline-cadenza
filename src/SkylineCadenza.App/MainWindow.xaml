<Window x:Class="SkylineCadenza.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:SkylineCadenza.App.ViewModels"
        xmlns:sched="clr-namespace:SkylineCadenza.Core.Scheduling;assembly=SkylineCadenza.Core"
        xmlns:scott="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
        Title="Skyline Cadenza" Width="1340" Height="880"
        Icon="pack://application:,,,/assets/cadenza.ico">
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>
    <Window.Resources>
        <vm:EnumEqualsConverter x:Key="EnumEq"/>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="380"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Parameter panel -->
        <ScrollViewer Grid.Column="0" Margin="8" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Logo header -->
                <Image Source="pack://application:,,,/assets/logo.jpg" Stretch="Uniform"
                       MaxHeight="120" HorizontalAlignment="Center" Margin="0,0,0,12"/>

                <!-- Inputs -->
                <TextBlock Text="Inputs" FontWeight="Bold" Margin="0,0,0,4"/>
                <TextBlock Text="DIA-NN report.parquet"/>
                <DockPanel LastChildFill="True">
                    <Button DockPanel.Dock="Right" Content="..." Width="32" Command="{Binding BrowseReportCommand}" Margin="4,0,0,0"/>
                    <TextBox Text="{Binding ReportPath, UpdateSourceTrigger=PropertyChanged}"/>
                </DockPanel>
                <TextBlock Text="Carafe library TSV (optional)" Margin="0,8,0,0"/>
                <DockPanel LastChildFill="True">
                    <Button DockPanel.Dock="Right" Content="..." Width="32" Command="{Binding BrowseCarafeCommand}" Margin="4,0,0,0"/>
                    <TextBox Text="{Binding CarafeTsvPath, UpdateSourceTrigger=PropertyChanged}"/>
                </DockPanel>
                <Button Content="Load + schedule" Command="{Binding LoadCommand}" Margin="0,8,0,4"/>
                <DockPanel LastChildFill="True" Margin="0,0,0,4">
                    <Button DockPanel.Dock="Right" Content="Cancel" Width="64"
                            Command="{Binding CancelSkylineLoadCommand}"
                            IsEnabled="{Binding SkylineLoadCancellable}"
                            Margin="4,0,0,0"/>
                    <Button Content="Load from Skyline document (preview)" Command="{Binding LoadFromSkylineCommand}"
                            IsEnabled="{Binding SkylineConnected}"/>
                </DockPanel>
                <ProgressBar IsIndeterminate="True" Height="6" Margin="0,0,0,4">
                    <ProgressBar.Style>
                        <Style TargetType="ProgressBar">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ProgressBar.Style>
                </ProgressBar>
                <TextBlock Text="{Binding SkylineStatus}" FontSize="11" Opacity="0.7" TextWrapping="Wrap" Margin="0,0,0,16"/>

                <!-- Target protein list -->
                <TextBlock Text="Target protein list" FontWeight="Bold" Margin="0,0,0,4"/>
                <TextBlock Text="Paste a FASTA, accessions (one per line), or gene symbols. Or:" TextWrapping="Wrap" FontSize="11" Opacity="0.7"/>
                <Button Content="Open FASTA / list..." Command="{Binding BrowseTargetListCommand}" HorizontalAlignment="Left" Margin="0,2,0,4"/>
                <TextBox Text="{Binding TargetProteinsText, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         Height="80" FontFamily="Consolas" FontSize="11"/>
                <TextBlock Text="{Binding TargetProteinsParsedCount, StringFormat='Parsed: {0} accessions resolved'}" FontSize="11" Opacity="0.7" Margin="0,2,0,4"/>
                <RadioButton Content="Target list first, fill with rest" GroupName="targetMode"
                             IsChecked="{Binding TargetMode, Converter={StaticResource EnumEq}, ConverterParameter={x:Static sched:TargetListMode.FirstThenFill}}"/>
                <RadioButton Content="Exclusive (target list only)" GroupName="targetMode"
                             IsChecked="{Binding TargetMode, Converter={StaticResource EnumEq}, ConverterParameter={x:Static sched:TargetListMode.Exclusive}}"/>

                <!-- Acquisition mode -->
                <TextBlock Text="Acquisition mode" FontWeight="Bold" Margin="0,16,0,4"/>
                <RadioButton Content="MTM (multiplex)" GroupName="mode"
                             IsChecked="{Binding Mode, Converter={StaticResource EnumEq}, ConverterParameter={x:Static sched:AcquisitionMode.Mtm}}"/>
                <RadioButton Content="PRM (1 precursor / slot)" GroupName="mode"
                             IsChecked="{Binding Mode, Converter={StaticResource EnumEq}, ConverterParameter={x:Static sched:AcquisitionMode.Prm}}"/>
                <CheckBox Content="Load balancing (fill remaining budget)" IsChecked="{Binding EnableLoadBalancing}" Margin="0,8,0,0"/>

                <!-- MTM constraints -->
                <TextBlock Text="MTM constraints" FontWeight="Bold" Margin="0,16,0,4"/>
                <TextBlock Text="{Binding IsolationWindowTh, StringFormat='Isolation window cap: {0:0.0} Th'}"/>
                <Slider Minimum="1.0" Maximum="4.0" TickFrequency="0.5" Value="{Binding IsolationWindowTh}"/>
                <TextBlock Text="{Binding FragmentTolDa, StringFormat='Fragment tolerance: {0:0.00} Da'}" Margin="0,4,0,0"/>
                <Slider Minimum="0.05" Maximum="1.0" TickFrequency="0.05" Value="{Binding FragmentTolDa}"/>
                <TextBlock Text="{Binding PrmIsolationWidthTh, StringFormat='PRM / solo-slot window width: {0:0.0} Th'}" Margin="0,4,0,0"/>
                <Slider Minimum="0.4" Maximum="2.0" TickFrequency="0.1" Value="{Binding PrmIsolationWidthTh}"/>

                <TextBlock Text="Charge handling per slot" Margin="0,8,0,2"/>
                <RadioButton Content="Match charge per slot" GroupName="chargeHandling"
                             IsChecked="{Binding ChargeHandling, Converter={StaticResource EnumEq}, ConverterParameter={x:Static sched:ChargeHandling.SameChargePerSlot}}"/>
                <RadioButton Content="Allow mixed (use slot majority charge)" GroupName="chargeHandling"
                             IsChecked="{Binding ChargeHandling, Converter={StaticResource EnumEq}, ConverterParameter={x:Static sched:ChargeHandling.AllowMixed}}"/>

                <!-- Cycle budget -->
                <TextBlock Text="Cycle budget" FontWeight="Bold" Margin="0,16,0,4"/>
                <TextBlock Text="{Binding CycleBudget, StringFormat='Concurrent slots: {0}'}"/>
                <Slider Minimum="20" Maximum="200" TickFrequency="10" IsSnapToTickEnabled="True" Value="{Binding CycleBudget}"/>
                <TextBlock Text="{Binding FiringPadSec, StringFormat='RT buffer (each side): {0:0} s'}" Margin="0,4,0,0"/>
                <Slider Minimum="0" Maximum="60" TickFrequency="5" IsSnapToTickEnabled="True" Value="{Binding FiringPadSec}"/>

                <!-- Per-protein bounds -->
                <TextBlock Text="Per-protein peptide bounds" FontWeight="Bold" Margin="0,16,0,4"/>
                <TextBlock Text="{Binding MinPeptidesPerProtein, StringFormat='Minimum peptides per protein: {0}'}"/>
                <Slider Minimum="1" Maximum="6" TickFrequency="1" IsSnapToTickEnabled="True" Value="{Binding MinPeptidesPerProtein}"/>
                <TextBlock Text="{Binding MaxPeptidesPerProtein, StringFormat='Maximum peptides per protein: {0}'}" Margin="0,4,0,0"/>
                <Slider Minimum="1" Maximum="10" TickFrequency="1" IsSnapToTickEnabled="True" Value="{Binding MaxPeptidesPerProtein}"/>

                <!-- Priority knobs -->
                <TextBlock Text="Protein ranking" FontWeight="Bold" Margin="0,16,0,4"/>
                <ComboBox SelectedItem="{Binding ProteinRanking}">
                    <sched:ProteinPriority>SummedIntensity</sched:ProteinPriority>
                    <sched:ProteinPriority>ProteinQValue</sched:ProteinPriority>
                    <sched:ProteinPriority>ProvidedListOrder</sched:ProteinPriority>
                </ComboBox>
                <TextBlock Text="Peptide ranking" FontWeight="Bold" Margin="0,12,0,4"/>
                <ComboBox SelectedItem="{Binding PeptideRanking}">
                    <sched:PeptidePriority>PrecursorQuantity</sched:PeptidePriority>
                    <sched:PeptidePriority>QValue</sched:PeptidePriority>
                </ComboBox>

                <!-- Library filter -->
                <TextBlock Text="Library filter" FontWeight="Bold" Margin="0,16,0,4"/>
                <TextBlock Text="{Binding QValueCutoff, StringFormat='Q value cutoff: {0:0.0000}'}"/>
                <Slider Minimum="0.001" Maximum="0.05" TickFrequency="0.001" Value="{Binding QValueCutoff}"/>

                <TextBlock Text="Output" FontWeight="Bold" Margin="0,16,0,4"/>
                <TextBlock Text="{Binding NormalizedCollisionEnergy, StringFormat='Normalized CE: {0:0.0}'}"/>
                <Slider Minimum="15" Maximum="40" TickFrequency="1" IsSnapToTickEnabled="True" Value="{Binding NormalizedCollisionEnergy}"/>
                <Button Content="Export Thermo CSV..." Command="{Binding ExportThermoCsvCommand}" Margin="0,4,0,4"/>
                <Button Content="Push targets to Skyline" Command="{Binding UpdateSkylineCommand}"
                        IsEnabled="{Binding SkylineConnected}"/>

                <TextBlock Text="{Binding StatusMessage}" Margin="0,16,0,0" TextWrapping="Wrap" FontStyle="Italic"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Plot pane: right-side dashboard -->
        <Grid Grid.Column="1" Margin="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Summary strip -->
            <Border Grid.Row="0" Padding="8" BorderBrush="LightGray" BorderThickness="0,0,0,1" Background="#fafafa">
                <StackPanel>
                <TextBlock Margin="0,0,0,4" FontSize="11" Opacity="0.7">
                    <Run Text="Library: "/>
                    <Run Text="{Binding LibraryPrecursors, StringFormat={}{0:n0}, Mode=OneWay}" FontWeight="Bold"/>
                    <Run Text=" precursors, "/>
                    <Run Text="{Binding LibraryPeptides, StringFormat={}{0:n0}, Mode=OneWay}" FontWeight="Bold"/>
                    <Run Text=" peptides, "/>
                    <Run Text="{Binding LibraryProteinGroups, StringFormat={}{0:n0}, Mode=OneWay}" FontWeight="Bold"/>
                    <Run Text=" protein groups"/>
                </TextBlock>
                <UniformGrid Rows="1" Columns="7">
                    <StackPanel>
                        <TextBlock Text="Precursors" Opacity="0.6" FontSize="11"/>
                        <TextBlock Text="{Binding ScheduledPrecursors, StringFormat='{}{0:n0}'}" FontSize="20" FontWeight="Bold"/>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="Peptides" Opacity="0.6" FontSize="11"/>
                        <TextBlock Text="{Binding ScheduledPeptides, StringFormat='{}{0:n0}'}" FontSize="20" FontWeight="Bold"/>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="Protein groups" Opacity="0.6" FontSize="11"/>
                        <TextBlock Text="{Binding ProteinsCovered, StringFormat='{}{0:n0}'}" FontSize="20" FontWeight="Bold"/>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="{Binding SlotsLabel}" Opacity="0.6" FontSize="11"/>
                        <TextBlock Text="{Binding SlotsTotal, StringFormat='{}{0:n0}'}" FontSize="20" FontWeight="Bold"/>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="Slots multiplexed" Opacity="0.6" FontSize="11"/>
                        <TextBlock Text="{Binding SlotsShared, StringFormat='{}{0:n0}'}" FontSize="20" FontWeight="Bold"/>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="Peak load" Opacity="0.6" FontSize="11"/>
                        <TextBlock Text="{Binding PeakLoad}" FontSize="20" FontWeight="Bold"/>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="Median peptides/protein" Opacity="0.6" FontSize="11"/>
                        <TextBlock Text="{Binding MedianPeptidesPerProtein, StringFormat='{}{0:0.0}'}" FontSize="20" FontWeight="Bold"/>
                    </StackPanel>
                </UniformGrid>
                </StackPanel>
            </Border>

            <!-- Plot tabs -->
            <TabControl Grid.Row="1">
                <TabItem Header="Cycle load">
                    <scott:WpfPlot x:Name="LoadCurvePlot"/>
                </TabItem>
                <TabItem Header="Protein coverage">
                    <scott:WpfPlot x:Name="CoveragePlot"/>
                </TabItem>
                <TabItem Header="Per-run coverage">
                    <scott:WpfPlot x:Name="PerRunPlot"/>
                </TabItem>
                <TabItem Header="m/z x RT heatmap">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="8,4">
                            <TextBlock Text="Show:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <RadioButton Content="Full library density" GroupName="heatmapView" Margin="0,0,12,0"
                                         IsChecked="{Binding HeatmapView, Converter={StaticResource EnumEq}, ConverterParameter={x:Static vm:HeatmapView.FullLibrary}}"/>
                            <RadioButton Content="Scheduled isolation windows" GroupName="heatmapView"
                                         IsChecked="{Binding HeatmapView, Converter={StaticResource EnumEq}, ConverterParameter={x:Static vm:HeatmapView.ScheduledAssay}}"/>
                        </StackPanel>
                        <scott:WpfPlot x:Name="HeatmapPlot"/>
                    </DockPanel>
                </TabItem>
                <TabItem Header="Slot occupancy">
                    <scott:WpfPlot x:Name="OccupancyPlot"/>
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
</Window>
